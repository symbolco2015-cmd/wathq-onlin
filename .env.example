# ── Server-side only (never exposed to the browser) ──────────────────────────
# Required for AI features. Used exclusively by server.js (/api/gemini proxy).
# Do NOT prefix with VITE_ — must NOT appear in the client bundle.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Port for the Express proxy server (default: 3001)
SERVER_PORT=3001

# The URL where this app is hosted (used for CORS in server.js and OAuth callbacks)
APP_URL="MY_APP_URL"

# ── Client-side (safe to expose — Supabase anon key is intentionally public) ──
VITE_SUPABASE_URL="your-supabase-url"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
